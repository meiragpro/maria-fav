---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
const { title, description, image, amazonUrl, price, rating } = post.data;
const stars = rating ? "★".repeat(rating) + "☆".repeat(5 - rating) : null;
---

<Layout title={`${title} — Maria's Fav`} description={description}>
  <article class="post">
    <a href="/" class="back">← Back to the edit</a>

    <header class="post-head">
      {stars && <p class="stars">{stars}</p>}
      <h1>{title}</h1>
      <p class="sub">{description}</p>
    </header>

    <img class="hero" src={image} alt={title} />

    <a class="buy-big" href={amazonUrl} target="_blank" rel="nofollow sponsored noopener">
      View on Amazon{price ? ` · ${price}` : ''} →
    </a>

    <div class="content">
      <Content />
    </div>

    <a class="buy-big" href={amazonUrl} target="_blank" rel="nofollow sponsored noopener">
      View on Amazon{price ? ` · ${price}` : ''} →
    </a>
  </article>
</Layout>

<style>
  .post { max-width: 680px; margin: 0 auto; }
  .back {
    display: inline-block;
    margin-bottom: 1.5rem;
    text-decoration: none;
    font-size: 0.85rem;
    letter-spacing: 0.5px;
    color: var(--muted);
  }
  .back:hover { color: var(--ink); }
  .post-head { text-align: center; margin-bottom: 2rem; }
  .stars { color: var(--accent); letter-spacing: 3px; margin: 0 0 0.6rem; }
  h1 { font-family: var(--serif); font-size: 2.6rem; font-weight: 600; margin: 0 0 0.6rem; line-height: 1.15; }
  .sub { font-family: var(--serif); font-style: italic; font-size: 1.25rem; color: var(--muted); margin: 0; }
  .hero {
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    border-radius: 20px;
    background: #faeef0;
    margin-bottom: 2rem;
  }
  .buy-big {
    display: inline-block;
    background: var(--accent);
    color: #fff;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.9rem;
    letter-spacing: 0.5px;
    padding: 0.9rem 1.9rem;
    border-radius: 999px;
    margin: 0.5rem 0 2rem;
    transition: background 0.2s ease, transform 0.15s ease;
  }
  .buy-big:hover { background: var(--accent-dark); transform: translateY(-1px); }
  .content { font-size: 1.08rem; }
  .content :global(h2) { font-family: var(--serif); font-size: 1.7rem; font-weight: 600; margin-top: 2rem; }
  .content :global(img) { max-width: 100%; border-radius: 6px; }
</style>
