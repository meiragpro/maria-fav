---
interface Props {
  title?: string;
  description?: string;
}
const {
  title = "Maria's Fav",
  description = "Maria's favorite products — a curated edit of things I genuinely love.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#b08968" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,500;0,600;1,500&family=Inter:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <a href="/" class="logo">Maria's Fav</a>
      <span class="rule" aria-hidden="true"></span>
      <p class="tagline">A curated edit of things I genuinely love</p>
      <nav class="site-nav">
        <a href="/">The Edit</a>
        <a href="/about/">About</a>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <span class="rule" aria-hidden="true"></span>
      <p class="disclosure">
        <strong>Affiliate disclosure:</strong> As an Amazon Associate I earn from
        qualifying purchases. Links on this site may earn me a small commission at
        no extra cost to you.
      </p>
      <nav class="footer-nav">
        <a href="/">The Edit</a>
        <a href="/about/">About</a>
        <a href="/privacy/">Privacy Policy</a>
      </nav>
      <p class="copyright">© {new Date().getFullYear()} Maria's Fav · Made with care</p>
    </footer>

    <style is:global>
      :root {
        --accent: #b08968;        /* warm taupe / soft camel */
        --accent-dark: #8c6b52;
        --ink: #2b2b2b;
        --muted: #8a8579;
        --bg: #faf7f2;            /* warm cream */
        --card: #ffffff;
        --line: #e8e2d8;
        --serif: "Cormorant Garamond", Georgia, serif;
        --sans: "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      }
      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body {
        margin: 0;
        font-family: var(--sans);
        color: var(--ink);
        background: var(--bg);
        line-height: 1.65;
        -webkit-font-smoothing: antialiased;
      }
      main { max-width: 1080px; margin: 0 auto; padding: 0 1.5rem 4rem; }
      a { color: var(--accent-dark); }

      .rule {
        display: block;
        width: 44px;
        height: 1px;
        background: var(--accent);
        margin: 1.1rem auto;
        opacity: 0.7;
      }

      .site-header {
        text-align: center;
        padding: 3.5rem 1rem 2rem;
      }
      .logo {
        font-family: var(--serif);
        font-size: 2.7rem;
        font-weight: 600;
        text-decoration: none;
        color: var(--ink);
        letter-spacing: 0.5px;
      }
      .tagline {
        font-family: var(--serif);
        font-style: italic;
        font-size: 1.2rem;
        color: var(--muted);
        margin: 0;
      }
      .site-nav {
        margin-top: 1.4rem;
        display: flex;
        justify-content: center;
        gap: 2rem;
      }
      .site-nav a, .footer-nav a {
        text-decoration: none;
        color: var(--muted);
        font-size: 0.8rem;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        font-weight: 500;
        transition: color 0.2s ease;
      }
      .site-nav a:hover, .footer-nav a:hover { color: var(--accent-dark); }
      .footer-nav {
        display: flex;
        justify-content: center;
        flex-wrap: wrap;
        gap: 1.5rem;
        margin-bottom: 1rem;
      }

      .site-footer {
        max-width: 1080px;
        margin: 3rem auto 0;
        padding: 1rem 1.5rem 3.5rem;
        text-align: center;
      }
      .disclosure {
        font-size: 0.82rem;
        color: var(--muted);
        max-width: 600px;
        margin: 0 auto 0.6rem;
        letter-spacing: 0.2px;
      }
      .copyright {
        font-size: 0.78rem;
        color: var(--muted);
        margin: 0;
        letter-spacing: 0.5px;
        text-transform: uppercase;
      }
    </style>
  </body>
</html>
