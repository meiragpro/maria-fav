---
interface Props {
  title: string;
  description: string;
  image: string;
  href: string;        // link to the full post
  amazonUrl: string;
  price?: string;
  rating?: number;
}
const { title, description, image, href, amazonUrl, price, rating } = Astro.props;
const stars = rating ? "★".repeat(rating) + "☆".repeat(5 - rating) : null;
---

<article class="card">
  <a href={href} class="thumb-link">
    <img src={image} alt={title} loading="lazy" />
    {rating === 5 && <span class="badge">Maria's pick</span>}
  </a>
  <div class="body">
    {stars && <p class="stars">{stars}</p>}
    <h2><a href={href}>{title}</a></h2>
    <p class="desc">{description}</p>
    <div class="row">
      {price && <span class="price">{price}</span>}
      <a class="buy" href={amazonUrl} target="_blank" rel="nofollow sponsored noopener">
        View on Amazon →
      </a>
    </div>
  </div>
</article>

<style>
  .card {
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: 6px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }
  .card:hover {
    transform: translateY(-4px);
    box-shadow: 0 18px 40px rgba(43, 43, 43, 0.08);
  }
  .thumb-link {
    display: block;
    position: relative;
    aspect-ratio: 4 / 3;
    background: #f3eee6;
    overflow: hidden;
  }
  .thumb-link img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }
  .card:hover .thumb-link img { transform: scale(1.04); }
  .badge {
    position: absolute;
    top: 0.85rem;
    left: 0.85rem;
    background: rgba(255, 255, 255, 0.92);
    color: var(--accent-dark);
    font-size: 0.68rem;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    font-weight: 600;
    padding: 0.35rem 0.7rem;
    border-radius: 2px;
    backdrop-filter: blur(4px);
  }
  .body { padding: 1.4rem 1.4rem 1.5rem; display: flex; flex-direction: column; flex: 1; }
  .stars { color: var(--accent); margin: 0 0 0.35rem; letter-spacing: 3px; font-size: 0.85rem; }
  h2 { font-family: var(--serif); font-size: 1.5rem; font-weight: 600; margin: 0 0 0.5rem; line-height: 1.2; }
  h2 a { text-decoration: none; color: var(--ink); }
  .desc { color: var(--muted); font-size: 0.95rem; margin: 0 0 1.4rem; flex: 1; }
  .row { display: flex; align-items: center; justify-content: space-between; gap: 0.75rem; }
  .price { font-family: var(--serif); font-weight: 600; font-size: 1.3rem; }
  .buy {
    color: var(--accent-dark);
    text-decoration: none;
    font-weight: 600;
    font-size: 0.85rem;
    letter-spacing: 0.5px;
    border-bottom: 1px solid var(--accent);
    padding-bottom: 2px;
    white-space: nowrap;
    transition: color 0.2s ease, border-color 0.2s ease;
  }
  .buy:hover { color: var(--ink); border-color: var(--ink); }
</style>
